# Copie para .env e preencha os valores reais
# Nunca comite o .env

# Banco de dados remoto (mysql.gdac.com.br)
# Production: database=gdac_auth, user=gdac
DB_PROD_PASSWORD=altere_aqui

# Staging: database=gdac_auth_stg, user=gdac01
DB_STG_PASSWORD=altere_aqui

REDIS_PASSWORD=altere_aqui

# Cole o conteúdo do arquivo PEM (quebras de linha como \n)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

JWT_ISSUER=https://auth.gdac.com.br
JWT_AUDIENCE=gdac-apps

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=noreply@gdac.com.br
EMAIL_PASSWORD=altere_aqui
EMAIL_FROM=noreply@gdac.com.br

APP_BASE_URL=https://auth.gdac.com.br

REGISTRY=ghcr.io
IMAGE_NAME=mouragoncalves/gdac-auth
IMAGE_TAG=latest

ASPNETCORE_ENVIRONMENT=Production
